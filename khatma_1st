<body>
<div id="root"></div>

<script type="text/babel">
const { useState, useEffect, useCallback, useRef } = React;

// ── Constants ──
const JUZ_NAMES = ["الم","سَيقول","تِلكَ الرُّسُل","لَن تَنالُوا","والمُحصَنات","لا يُحِبُّ الله","وإذا سَمِعوا","وَلَو أنَّنا","قالَ المَلأ","واعلَموا","يَعتَذِرونَ","وَما مِن دابَّة","وَما أُبَرِّئ","رُبَما","سُبحانَ الَّذي","قالَ ألَم","اقتَرَبَ","قَد أفلَحَ","وقالَ الَّذينَ","أمَّن خَلَقَ","اتلُ ما أوحِيَ","وَمَن يَقنُت","وما لِيَ","فَمَن أَظلَم","إليهِ يُرَدُّ","حم","قالَ فَما خَطبُكم","قَد سَمِعَ اللَّه","تَبارَكَ الَّذي","عَمَّ يَتَساءَلون"];
const ARABIC_NUM = ["١","٢","٣","٤","٥","٦","٧","٨","٩","١٠","١١","١٢","١٣","١٤","١٥","١٦","١٧","١٨","١٩","٢٠","٢١","٢٢","٢٣","٢٤","٢٥","٢٦","٢٧","٢٨","٢٩","٣٠"];
const ORDINALS = ["الأولى","الثانية","الثالثة","الرابعة","الخامسة","السادسة","السابعة","الثامنة","التاسعة","العاشرة","الحادية عشرة","الثانية عشرة","الثالثة عشرة","الرابعة عشرة","الخامسة عشرة"];
const STORAGE_KEY = "quran_khatmat_v4";

// ── Storage (localStorage only — works on GitHub Pages) ──
const loadData = () => {
  try { const r = localStorage.getItem(STORAGE_KEY); return r ? JSON.parse(r) : null; }
  catch { return null; }
};
const saveData = (data) => {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); } catch {}
};

// ── Factories ──
const makeJuz = (i) => ({ number:i+1, name:JUZ_NAMES[i], status:"available", reservedBy:null, reservedAt:null, completedAt:null });
const makeKhatma = (idx) => ({
  id: `k_${Date.now()}_${Math.random().toString(36).slice(2)}`,
  name: `الختمة ${ORDINALS[idx] ?? `رقم ${idx+1}`}`,
  createdAt: new Date().toISOString(),
  juzList: Array.from({length:30}, (_,i) => makeJuz(i))
});
const initData = () => ({ khatmat:[makeKhatma(0)] });

// ── Helpers ──
const getStats = (k) => {
  if (!k) return {av:0,rs:0,cp:0};
  return {
    av: k.juzList.filter(j=>j.status==="available").length,
    rs: k.juzList.filter(j=>j.status==="reserved").length,
    cp: k.juzList.filter(j=>j.status==="completed").length,
  };
};
const formatDate = (iso) => {
  if (!iso) return "";
  try { return new Date(iso).toLocaleDateString("ar-EG",{year:"numeric",month:"long",day:"numeric"}); }
  catch { return ""; }
};

// ── App ──
function App() {
  const [data, setData]           = useState(null);
  const [loading, setLoading]     = useState(true);
  const [activeId, setActiveId]   = useState(null);
  const [userName, setUserName]   = useState("");
  const [search, setSearch]       = useState("");
  const [selJuz, setSelJuz]       = useState(null);
  const [modal, setModal]         = useState(null);
  const [toast, setToast]         = useState(null);
  const [adminOpen, setAdminOpen] = useState(false);
  const [delConfirm, setDelConfirm] = useState(null);
  const pollRef = useRef(null);

  // ── Toast ──
  const showToast = useCallback((msg, type="success") => {
    setToast({msg,type});
    setTimeout(() => setToast(null), 3500);
  }, []);

  // ── Load + cleanup ──
  const loadAndClean = useCallback((initial=false) => {
    let d = loadData();
    if (!d || !d.khatmat || !d.khatmat.length) { d = initData(); saveData(d); }

    // Remove any empty khatma whose previous khatma still has available juz
    let changed = false;
    d.khatmat = d.khatmat.filter((k, i) => {
      if (i === 0) return true;
      const prevHasAvail = d.khatmat[i-1].juzList.some(j => j.status === "available");
      const thisEmpty    = k.juzList.every(j => j.status === "available");
      if (thisEmpty && prevHasAvail) { changed = true; return false; }
      return true;
    });
    if (changed) saveData(d);

    setData({...d});
    if (initial) {
      setActiveId(d.khatmat[d.khatmat.length-1].id);
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    const saved = localStorage.getItem("khatma_username");
    if (saved) setUserName(saved);
    loadAndClean(true);
    pollRef.current = setInterval(() => loadAndClean(false), 2000);
    return () => clearInterval(pollRef.current);
  }, [loadAndClean]);

  useEffect(() => { if (userName) localStorage.setItem("khatma_username", userName); }, [userName]);

  // ── Derived ──
  const activeKhatma = data?.khatmat.find(k => k.id === activeId);
  const stats  = getStats(activeKhatma);
  const cpPct  = activeKhatma ? Math.round((stats.cp/30)*100) : 0;
  const rsPct  = activeKhatma ? Math.round((stats.rs/30)*100) : 0;
  const allDone = activeKhatma?.juzList.every(j => j.status === "completed");

  const juzWithHL = (activeKhatma?.juzList || []).map(j => ({
    ...j,
    hl: !!search.trim() && !!j.reservedBy?.toLowerCase().includes(search.trim().toLowerCase())
  }));
  const searchHits = juzWithHL.filter(j => j.hl);

  // ── Reserve ──
  const handleReserve = () => {
    const name = userName.trim();
    if (!name) { showToast("يرجى إدخال اسمك أولاً ✏️","error"); return; }
    if (!selJuz || !activeId) return;

    const d = loadData() || initData();
    const ki = d.khatmat.findIndex(k => k.id === activeId);
    if (ki === -1) return;
    const ji = d.khatmat[ki].juzList.findIndex(j => j.number === selJuz.number);

    if (d.khatmat[ki].juzList[ji].status !== "available") {
      showToast("تم حجز هذا الجزء للتو من شخص آخر ⚡","error");
      setData({...d}); setModal(null); return;
    }

    d.khatmat[ki].juzList[ji] = { ...d.khatmat[ki].juzList[ji], status:"reserved", reservedBy:name, reservedAt:new Date().toISOString() };
    saveData(d);
    setData({...d});
    setModal(null);
    showToast(`✓ تم حجز الجزء ${selJuz.number} باسم ${name}`);

    // Auto-open new khatma when all 30 are reserved
    const allReserved = d.khatmat[ki].juzList.every(j => j.status !== "available");
    const isLast = ki === d.khatmat.length - 1;
    if (allReserved && isLast) {
      setTimeout(() => {
        const d2 = loadData() || d;
        const alreadyHasNew = d2.khatmat.some((k,i) => i > ki && k.juzList.every(j => j.status === "available"));
        if (!alreadyHasNew) {
          d2.khatmat.push(makeKhatma(d2.khatmat.length));
          saveData(d2);
          setData({...d2});
          showToast("🎉 اكتمل الحجز! تم فتح ختمة جديدة","gold");
        }
      }, 600);
    }
  };

  // ── Complete ──
  const handleComplete = () => {
    if (!selJuz || !activeId) return;
    const d = loadData() || initData();
    const ki = d.khatmat.findIndex(k => k.id === activeId);
    const ji = d.khatmat[ki].juzList.findIndex(j => j.number === selJuz.number);
    d.khatmat[ki].juzList[ji] = { ...d.khatmat[ki].juzList[ji], status:"completed", completedAt:new Date().toISOString() };
    saveData(d);
    setData({...d});
    setModal(null);
    showToast("🌟 بارك الله فيك! تم تسجيل إتمام الجزء","gold");
  };

  // ── Cancel ──
  const handleCancel = () => {
    if (!selJuz || !activeId) return;
    const d = loadData() || initData();
    const ki = d.khatmat.findIndex(k => k.id === activeId);
    const ji = d.khatmat[ki].juzList.findIndex(j => j.number === selJuz.number);
    d.khatmat[ki].juzList[ji] = makeJuz(selJuz.number - 1);
    saveData(d);
    setData({...d});
    setModal(null);
    showToast("تم إلغاء الحجز");
  };

  // ── Add khatma (manual) ──
  const addKhatma = () => {
    const d = loadData() || initData();
    const lastK = d.khatmat[d.khatmat.length - 1];
    if (lastK && lastK.juzList.some(j => j.status === "available")) {
      showToast("لا يمكن فتح ختمة جديدة قبل اكتمال حجز الختمة الحالية 🔒","error");
      return;
    }
    const nk = makeKhatma(d.khatmat.length);
    d.khatmat.push(nk);
    saveData(d);
    setData({...d});
    setActiveId(nk.id);
    showToast("تم إنشاء ختمة جديدة 🌿");
  };

  // ── Admin: reset ──
  const adminReset = (kid) => {
    const d = loadData() || initData();
    const ki = d.khatmat.findIndex(k => k.id === kid);
    d.khatmat[ki].juzList = Array.from({length:30}, (_,i) => makeJuz(i));
    saveData(d);
    setData({...d});
    showToast("تمت إعادة التعيين");
  };

  // ── Admin: delete ──
  const adminDelete = (kid) => {
    const d = loadData() || initData();
    d.khatmat = d.khatmat.filter(k => k.id !== kid);
    if (!d.khatmat.length) d.khatmat.push(makeKhatma(0));
    saveData(d);
    setData({...d});
    setDelConfirm(null);
    if (activeId === kid) setActiveId(d.khatmat[0].id);
    showToast("تم حذف الختمة");
  };

  // ── Loading screen ──
  if (loading) return (
    <div className="loading">
      <div className="spinner"/>
      <div>بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ</div>
      <div style={{fontSize:"1rem",color:"var(--txt3)"}}>جاري التحميل...</div>
    </div>
  );

  return (
    <div className="app-wrap" dir="rtl">

      {/* HEADER */}
      <header className="header">
        <div className="header-geo"/>
        <div className="header-inner">
          <div className="header-basmala">بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ</div>
          <h1 className="header-title">ختمات القرآن الكريم</h1>
          <p className="header-sub">احجز جزءك وشارك في إتمام كتاب الله</p>
          <div className="header-ornament">❧ ✦ ✦ ✦ ❧</div>
        </div>
        <div className="gold-bar"/>
      </header>

      {/* TAB BAR */}
      <div className="tab-bar">
        <div className="tab-inner">
          {data.khatmat.map(k => {
            const s = getStats(k);
            const done = s.cp === 30;
            const full = s.av === 0 && !done;
            return (
              <button key={k.id}
                className={`tab-btn${k.id===activeId?" active":""}${done?" done":""}`}
                onClick={() => setActiveId(k.id)}>
                {done ? "✅ " : full ? "🔒 " : ""}{k.name}
              </button>
            );
          })}
          <button className="tab-add" onClick={addKhatma}>
            <span style={{fontSize:"1.1rem",lineHeight:1}}>+</span> ختمة جديدة
          </button>
          <button className="tab-admin" onClick={() => setAdminOpen(v=>!v)}>
            ⚙️ الإدارة
          </button>
        </div>
      </div>

      {/* MAIN */}
      <main className="main">
        {activeKhatma && (<>

          {/* Khatma info card */}
          <div className="khatma-card">
            <div className="khatma-title"><span>📖</span> {activeKhatma.name}</div>
            <div className="khatma-meta">أُنشئت في {formatDate(activeKhatma.createdAt)}</div>

            {allDone && (
              <div className="complete-banner">
                <h3>🌟 تبارك الله — اكتمل ختم القرآن الكريم 🌟</h3>
                <p>جزى الله المشاركين خير الجزاء</p>
              </div>
            )}

            <div className="prog-header">
              <span className="prog-lbl">📊 تقدم الختمة</span>
              <span className="prog-pct">{cpPct}٪ مكتمل</span>
            </div>
            <div className="prog-track">
              <div className="prog-reserved" style={{width:`${rsPct+cpPct}%`}}/>
              <div className="prog-completed" style={{width:`${cpPct}%`}}/>
            </div>
            <div className="prog-stats">
              <span className="prog-stat"><span className="dot av"/>متاح: {stats.av} جزء</span>
              <span className="prog-stat"><span className="dot rs"/>محجوز: {stats.rs} جزء</span>
              <span className="prog-stat"><span className="dot cp"/>مكتمل: {stats.cp} جزء</span>
            </div>
          </div>

          {/* Controls */}
          <div className="controls">
            <div className="inp-wrap">
              <span className="inp-icon">👤</span>
              <input className="inp" placeholder="أدخل اسمك للحجز..." value={userName}
                onChange={e=>setUserName(e.target.value)} dir="rtl"/>
            </div>
            <div className="inp-wrap">
              <span className="inp-icon">🔍</span>
              <input className="inp" placeholder="ابحث باسم الشخص..." value={search}
                onChange={e=>setSearch(e.target.value)} dir="rtl"/>
            </div>
          </div>

          {/* Search result */}
          {search.trim() && (
            <div className="srch-result">
              {searchHits.length ? (
                <>
                  <span>نتائج البحث عن «<strong>{search}</strong>»:</span>
                  {searchHits.map(j => (
                    <span key={j.number} className="srch-badge">الجزء {j.number}</span>
                  ))}
                </>
              ) : (
                <span className="srch-none">لم يُعثر على «{search}» في هذه الختمة</span>
              )}
            </div>
          )}

          {/* Juz grid */}
          <div className="juz-grid">
            {juzWithHL.map(juz => (
              <div key={juz.number}
                className={`juz-card ${juz.status}${juz.hl?" hl":""}`}
                onClick={() => { setSelJuz(juz); setModal(juz.status==="available"?"reserve":"manage"); }}>
                <div className="juz-badge">{ARABIC_NUM[juz.number-1]}</div>
                <div className="juz-num-lbl">الجزء {juz.number}</div>
                {juz.status==="available" && <div className="juz-status">🟢 متاح</div>}
                {juz.status==="reserved" && (<>
                  <div className="juz-by">{juz.reservedBy}</div>
                  <div className="juz-status">📌 محجوز</div>
                </>)}
                {juz.status==="completed" && (<>
                  <div className="juz-by">{juz.reservedBy}</div>
                  <div className="juz-status">✅ مكتمل</div>
                </>)}
              </div>
            ))}
          </div>

        </>)}

        {/* ADMIN PANEL */}
        {adminOpen && (
          <div className="admin-panel">
            <div className="admin-head">
              <div className="admin-title">⚙️ لوحة الإدارة</div>
              <button className="btn btn-outline btn-sm" onClick={()=>setAdminOpen(false)}>إغلاق ✕</button>
            </div>
            {data.khatmat.map(k => {
              const s = getStats(k);
              const rPct = Math.round(((s.rs+s.cp)/30)*100);
              const cPct = Math.round((s.cp/30)*100);
              return (
                <div key={k.id} className="admin-row" style={k.id===activeId?{background:"var(--g6)"}:{}}>
                  <div className="admin-row-head">
                    <div className="admin-row-name">{k.name}</div>
                    <div className="admin-actions">
                      <button className="btn btn-outline btn-sm" onClick={()=>adminReset(k.id)}>🔄 إعادة تعيين</button>
                      {delConfirm===k.id ? (<>
                        <span style={{fontSize:".82rem",color:"var(--red)"}}>تأكيد الحذف؟</span>
                        <button className="btn btn-ghost btn-sm" onClick={()=>adminDelete(k.id)}>نعم، احذف</button>
                        <button className="btn btn-outline btn-sm" onClick={()=>setDelConfirm(null)}>إلغاء</button>
                      </>) : (
                        <button className="btn btn-ghost btn-sm" onClick={()=>setDelConfirm(k.id)}>🗑 حذف</button>
                      )}
                    </div>
                  </div>
                  <div className="admin-row-meta">متاح: {s.av} · محجوز: {s.rs} · مكتمل: {s.cp} · الحجز: {rPct}%</div>
                  <div className="prog-track" style={{height:"8px"}}>
                    <div className="prog-reserved" style={{width:`${rPct}%`}}/>
                    <div className="prog-completed" style={{width:`${cPct}%`}}/>
                  </div>
                  {k.juzList.some(j=>j.status!=="available") && (
                    <table className="tbl">
                      <thead><tr><th>الجزء</th><th>الاسم</th><th>الحالة</th><th>تاريخ الحجز</th></tr></thead>
                      <tbody>
                        {k.juzList.filter(j=>j.status!=="available").map(j=>(
                          <tr key={j.number}>
                            <td style={{fontFamily:"'Amiri',serif",fontWeight:600}}>الجزء {j.number}</td>
                            <td>{j.reservedBy||"—"}</td>
                            <td><span className={`badge ${j.status==="reserved"?"rs":"cp"}`}>{j.status==="reserved"?"📌 محجوز":"✅ مكتمل"}</span></td>
                            <td style={{fontSize:".78rem",color:"var(--txt3)"}}>{formatDate(j.reservedAt)||"—"}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  )}
                </div>
              );
            })}
          </div>
        )}

        <div className="footer">
          <div className="footer-orn">❧ ✦ ✦ ✦ ❧</div>
          <p>اللهم اجعل القرآن ربيع قلوبنا ونور صدورنا وجلاء أحزاننا وذهاب همومنا</p>
          <p style={{marginTop:5,fontSize:".75rem"}}>تُفتح ختمة جديدة تلقائياً عند اكتمال حجز الـ٣٠ جزء</p>
        </div>
      </main>

      {/* RESERVE MODAL */}
      {modal==="reserve" && selJuz && (
        <div className="overlay" onClick={()=>setModal(null)}>
          <div className="modal" onClick={e=>e.stopPropagation()}>
            <span className="modal-ico">📖</span>
            <div className="modal-title">حجز الجزء {selJuz.number}</div>
            <div className="modal-sub">أدخل اسمك الكريم لتثبيت حجزك في هذه الختمة</div>
            <input className="modal-inp" placeholder="اسمك الكريم..." value={userName}
              onChange={e=>setUserName(e.target.value)}
              onKeyDown={e=>e.key==="Enter"&&handleReserve()} autoFocus/>
            <div className="modal-actions">
              <button className="btn btn-primary" onClick={handleReserve} disabled={!userName.trim()}>✓ تأكيد الحجز</button>
              <button className="btn btn-outline" onClick={()=>setModal(null)}>إلغاء</button>
            </div>
          </div>
        </div>
      )}

      {/* MANAGE MODAL */}
      {modal==="manage" && selJuz && (
        <div className="overlay" onClick={()=>setModal(null)}>
          <div className="modal" onClick={e=>e.stopPropagation()}>
            <span className="modal-ico">{selJuz.status==="completed"?"✅":"📌"}</span>
            <div className="modal-title">الجزء {selJuz.number}</div>
            <div className="modal-info">
              <div className="modal-info-lbl">{selJuz.status==="completed"?"أتمّ هذا الجزء":"تم الحجز بواسطة"}</div>
              <div className="modal-info-name">{selJuz.reservedBy}</div>
              {selJuz.reservedAt && <div className="modal-info-date">بتاريخ {formatDate(selJuz.reservedAt)}</div>}
            </div>
            <div className="modal-actions">
              {selJuz.status==="reserved" && (<>
                <button className="btn btn-gold" onClick={handleComplete}>✅ تم الانتهاء من الجزء</button>
                <button className="btn btn-ghost" onClick={handleCancel}>🗑 إلغاء الحجز</button>
              </>)}
              {selJuz.status==="completed" && (
                <button className="btn btn-ghost" onClick={handleCancel}>↩️ إعادة الجزء للحجز</button>
              )}
              <button className="btn btn-outline" onClick={()=>setModal(null)}>إغلاق</button>
            </div>
          </div>
        </div>
      )}

      {/* TOAST */}
      {toast && <div className={`toast ${toast.type}`}>{toast.msg}</div>}

    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>
